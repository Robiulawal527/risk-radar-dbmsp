EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Deployed backend (used for production / release builds)
EXPO_PUBLIC_API_URL=https://your-backend.vercel.app/api

# Local backend used during development (__DEV__).
# When you run `pnpm dev` from the repo root (turbo starts backend + mobile together),
# the app should talk to your locally running backend on port 3001.
#
# Recommended for most local dev (simulator / Expo Go on same machine / tunnel):
EXPO_PUBLIC_API_URL_LOCAL=http://127.0.0.1:3001/api
#
# For a physical phone on the same Wi-Fi (LAN), you can either:
#   - Leave the above (many setups work via tunnel), or
#   - Set REACT_NATIVE_PACKAGER_HOSTNAME=192.168.0.105 (your Mac's LAN IP) in this file or the shell, or
#   - Change this line to http://192.168.0.105:3001/api
#
# The mobile env resolver is defensive: if a deployed URL is accidentally left here,
# dev mode will still prefer the local backend via Expo's debugger host detection.

EXPO_PUBLIC_API_TIMEOUT=10000
EXPO_PUBLIC_SUPABASE_CRIME_TABLE=crimes
EXPO_PUBLIC_NEARBY_ALERT_RADIUS_KM=10
