{
  "expo": {
    "name": "Risk Radar",
    "slug": "riskradar",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "riskradar",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.riskradar.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Risk Radar needs your location to show nearby crime data and provide safety alerts."
      }
    },
    "android": {
      "package": "com.riskradar.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Risk Radar to use your location to show nearby crime data."
        }
      ],
      "expo-notifications",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "68a33367-98a8-4076-bc1f-e6f315d18816"
      }
    },
    "owner": "robi527"
  }
}
