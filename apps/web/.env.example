# Deployed API (Vercel / production). Used by `app/api/backend/*` to forward requests in production builds.
NEXT_PUBLIC_API_URL=https://your-backend.vercel.app/api

# Local Express origin (default port 3001). Used by `app/api/backend/*` to proxy in development.
# If Next.js `next dev` uses the same host:port as this value, the proxy cannot reach Express — use http://127.0.0.1:3001/api while the site is on http://localhost:3000 (or run the API on a different port).
# Optional override (origin only, no /api path): http://127.0.0.1:4000
# BACKEND_PROXY_TARGET=http://127.0.0.1:3001
NEXT_PUBLIC_API_URL_LOCAL=http://127.0.0.1:3001/api

# Live map: load incidents directly from Supabase (optional)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: PostgREST table name(s). First match wins; then tries crimes, crime, Crime, incidents.
# Example: NEXT_PUBLIC_SUPABASE_CRIME_TABLE=my_incidents
# Comma-separated: NEXT_PUBLIC_SUPABASE_CRIME_TABLE=incidents,crimes
# NEXT_PUBLIC_SUPABASE_CRIME_TABLE=Crime


# Deployed backend (Vercel / prod). Web production builds use this.
NEXT_PUBLIC_API_URL=https://risk-radar-backend-one.vercel.app/api

# Local Express — proxy target in dev. Prefer 127.0.0.1 so it never matches the browser origin when the site is on http://localhost:* .
NEXT_PUBLIC_API_URL_LOCAL=http://127.0.0.1:3001/api
