# Deployed backend (production builds / release channels)
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app/api

# Optional server-only override for the Next.js API proxy (used by /api/backend/* routes).
# Use this if you want to force the proxy target independently of the client var.
# BACKEND_PROXY_TARGET=https://your-backend.up.railway.app

# Local Express backend used by the Next.js API proxy in development.
# When you run `pnpm dev` from the repo root, turbo starts the backend on :3001
# and the web app will proxy to it thanks to this value.
NEXT_PUBLIC_API_URL_LOCAL=http://127.0.0.1:3001/api

# Supabase browser client (for direct reads + realtime on the web)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Optional: PostgREST table name(s) for direct crime queries.
# First match wins; the code also tries common fallbacks (crimes, crime, Crime, incidents).
NEXT_PUBLIC_SUPABASE_CRIME_TABLE=crimes

# Nearby crime/SOS notification radius in kilometers (used by notifications hook + UI)
NEXT_PUBLIC_NEARBY_ALERT_RADIUS_KM=10

# Tip for full local dev:
# Keep NEXT_PUBLIC_API_URL pointing at your deployed backend (so production builds still work)
# and use NEXT_PUBLIC_API_URL_LOCAL for the locally running backend started by `pnpm dev`.
