{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd .. && pnpm install --frozen-lockfile",
  "buildCommand": "cd .. && pnpm exec turbo run build --filter=@risk-radar/backend...",
  "rewrites": [{ "source": "/", "destination": "/api" }],
  "functions": {
    "api/[[...slug]].ts": {
      "maxDuration": 30,
      "includeFiles": "dist/**"
    }
  }
}
