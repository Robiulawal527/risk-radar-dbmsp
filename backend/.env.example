# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Configuration (use a strong random secret in production)
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# Database (Supabase Postgres direct connection)
# On Vercel / Railway / Fly / Render, `packages/config` requires a non-local DATABASE_URL plus JWT_SECRET and SUPABASE_SERVICE_ROLE_KEY.
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# Server
PORT=3001
# Comma-separated browser origins allowed to call this API (CORS).
# Include your Vercel web app, e.g. https://risk-radar-web-six.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://risk-radar-web-six.vercel.app
# Note: https://*.vercel.app preview URLs are allowed automatically in code.
# Socket.IO in src/index.ts does not run on Vercel serverless — use Railway/VM for realtime SOS if needed.
# Nearby-incident alert radius in km (default is sqrt(10/pi) ≈ 1.78km)
NEARBY_ALERT_RADIUS_KM=1.784
