{
  "name": "risk-radar",
  "private": true,
  "version": "1.0.0",
  "description": "Risk Radar - Crime Analytics and Safety Platform",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter @risk-radar/web run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "web": "turbo run dev --filter=@risk-radar/web",
    "mobile": "turbo run dev --filter=@risk-radar/mobile",
    "backend": "turbo run dev --filter=@risk-radar/backend",
    "env:sync": "node scripts/sync-env.js",
    "docker:web-mobile": "docker compose --env-file .env.docker up --build web mobile",
    "docker:full": "docker compose --env-file .env.docker --profile backend up --build",
    "docker:down": "docker compose --env-file .env.docker --profile backend down",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "prettier": "^3.0.0",
    "turbo": "^2.9.16",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {},
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "^5.8.0",
      "postcss": "^8.5.15",
      "qs": "^6.15.2",
      "uuid": "^14.0.0",
      "ws": "^8.21.0"
    }
  }
}
