# Copy this file to .env.docker before running docker compose.
# Keep .env.docker private; it may contain your Supabase database and service role secrets.

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=https://your-backend.vercel.app/api
NEXT_PUBLIC_API_URL_LOCAL=http://127.0.0.1:3001/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
NEXT_PUBLIC_SUPABASE_CRIME_TABLE=crimes
NEXT_PUBLIC_NEARBY_ALERT_RADIUS_KM=10

# Optional: force the web API proxy to a backend origin.
# For the Docker backend profile, use http://backend:3001.
BACKEND_PROXY_TARGET=

# Expo mobile
EXPO_PORT=8081
# Docker LAN mode may advertise a container IP that phones cannot reach.
# Use tunnel for the smoothest Expo Go testing experience.
EXPO_HOST=tunnel
EXPO_PUBLIC_API_URL=https://your-backend.vercel.app/api
# Expo dev builds prefer this value. Use your deployed backend URL for tunnel mode,
# or http://YOUR_COMPUTER_LAN_IP:3001/api when testing the Docker backend from a phone.
EXPO_PUBLIC_API_URL_LOCAL=https://your-backend.vercel.app/api
EXPO_PUBLIC_API_TIMEOUT=10000
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
EXPO_PUBLIC_SUPABASE_CRIME_TABLE=crimes
EXPO_PUBLIC_NEARBY_ALERT_RADIUS_KM=10

# Optional backend container. Required only when you run with --profile backend.
BACKEND_PORT=3001
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
NEARBY_ALERT_RADIUS_KM=10
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081,http://localhost:19006
