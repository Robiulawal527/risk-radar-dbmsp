{
  "expo": {
    "name": "Risk Radar",
    "slug": "risk-radar",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "riskradar",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "bd.riskradar.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Risk Radar uses your location to warn you when you enter a high-risk zone.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Risk Radar monitors nearby risk zones while you are travelling."
      }
    },
    "android": {
      "package": "bd.riskradar.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "POST_NOTIFICATIONS"]
    },
    "plugins": [
      "expo-location",
      "expo-notifications"
    ],
    "extra": {
      "apiUrl": "http://localhost:5000/api/v1"
    }
  }
}
